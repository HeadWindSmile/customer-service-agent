APP_NAME=Customer Service Agent
APP_VERSION=0.1.0
APP_ENV=local
MEMORY_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
MEMORY_TTL_SECONDS=604800
MEMORY_RECENT_TURNS=8
MEMORY_MAX_TURNS=8
MOCK_KNOWLEDGE_PATH=data/mock_knowledge.md
KNOWLEDGE_DIR=data/knowledge
VECTOR_STORE=mock
VECTOR_STORE_DIR=data/vector_store
CHROMA_COLLECTION=customer_service_knowledge
RAG_TOP_K=3
CHUNK_SIZE=500
CHUNK_OVERLAP=80
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_DIMENSIONS=768
EMBEDDING_TIMEOUT_SECONDS=10
LLM_PROVIDER=mock
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL_NAME=qwen-plus
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=10
INTENT_RULE_DIRECT_THRESHOLD=0.85
INTENT_LOW_CONFIDENCE_THRESHOLD=0.6
BUSINESS_SERVICE_BASE_URL=
BUSINESS_SERVICE_TIMEOUT_MS=800
BUSINESS_SERVICE_RETRY_ATTEMPTS=2
BUSINESS_SERVICE_RETRY_BACKOFF_MS=50
BUSINESS_SERVICE_MAX_CONNECTIONS=20
BUSINESS_SERVICE_MAX_KEEPALIVE_CONNECTIONS=10
BUSINESS_SERVICE_CIRCUIT_BREAKER_ENABLED=true
BUSINESS_SERVICE_CIRCUIT_FAILURE_THRESHOLD=3
BUSINESS_SERVICE_CIRCUIT_RESET_SECONDS=30
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=logs/audit.log
EVENT_PRODUCER=mock
EVENT_LOG_PATH=logs/events.jsonl
ROCKETMQ_NAME_SERVER=
ROCKETMQ_TOPIC=customer-service-agent-events
TRACE_ENABLED=true
TRACE_STORAGE_DIR=logs/traces
TRACE_INCLUDE_RAW_CONTENT=false
READINESS_TIMEOUT_SECONDS=1.5
METRICS_LITE_ENABLED=true
METRICS_LITE_WINDOW_SIZE=200
RAG_CACHE_ENABLED=true
RAG_CACHE_TTL_SECONDS=300
RAG_CACHE_MAX_SIZE=128
SAFETY_ENABLED=true
SAFETY_RULES_PATH=config/safety_rules.yml
SAFETY_REVIEW_QUEUE_PATH=logs/review_queue.jsonl
SAFETY_SEMANTIC_DETECTOR=mock
SAFETY_BLOCKED_WORDS=身份证号,银行卡密码,内部系统密码,忽略之前指令,绕过权限
OUTPUT_FORBIDDEN_PHRASES=保证赔偿,一定免费,内部数据,绝对不会
